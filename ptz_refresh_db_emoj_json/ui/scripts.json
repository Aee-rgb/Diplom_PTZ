        "min": 5,
        "max": 90
      },
      {
        "name": "step_delay",
        "label": "Задержка (сек)",
        "type": "float",
        "default": 0.3,
        "min": 0.1,
        "max": 2.0
      },
      {
        "name": "cycles",
        "label": "Циклы (0=∞)",
        "type": "int",
        "default": 0,
        "min": 0,
        "max": 100
      }
    ],
    "custom": false
  },
  "tilt_patrol": {
    "name": "Патруль: вверх-вниз",
    "description": "Автоматический наклон камеры по вертикали",
