        "default": "0,0,0;30,10,200;-30,-10,150",
        "multiline": true
      },
      {
        "name": "hold_time",
        "label": "Удержание (сек)",
        "type": "float",
        "default": 3.0,
        "min": 1.0,
        "max": 30.0
      }
    ],
    "custom": false
  },
  "reset_center": {
    "name": "Возврат в центр",
    "description": "Сброс камеры в исходное положение",
    "params": [],
    "custom": false
  },
  "scan_360": {
    "name": "Круговое сканирование",
