      {
        "name": "zoom_steps",
        "label": "Шагов зума",
        "type": "int",
        "default": 10,
        "min": 3,
        "max": 50
      },
      {
        "name": "step_delay",
        "label": "Задержка (сек)",
        "type": "float",
        "default": 0.2,
        "min": 0.05,
        "max": 1.0
      }
    ],
    "custom": false
  },
  "preset_tour": {
    "name": "Тур по позициям",
    "description": "Переход между заданными позициями",
    "params": [
      {
        "name": "positions",
        "label": "Позиции (pan,tilt,zoom;...)",
