      {
        "name": "tilt_range",
        "label": "Диапазон (°)",
        "type": "int",
        "default": 20,
        "min": 5,
        "max": 60
      },
      {
        "name": "step_delay",
        "label": "Задержка (сек)",
        "type": "float",
        "default": 0.3,
        "min": 0.1,
        "max": 2.0
      },
      {
        "name": "cycles",
        "label": "Циклы (0=∞)",
        "type": "int",
        "default": 0,
        "min": 0,
        "max": 100
      }
    ],
    "custom": false
  },
  "zoom_cycle": {
    "name": "Зум-цикл",
    "description": "Плавное увеличение и уменьшение зума",
